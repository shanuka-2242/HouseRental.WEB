<div class="col-md-4 p-2 d-flex">

	<div class="card shadow-sm h-100 w-100 rounded-3">

		<img src="@CardImageUrl"
			 class="card-img-top"
			 style="height: 300px; object-fit: cover;">

		<div class="px-3 mt-1">
			<label class="fs-6 fw-normal">Image Name:</label>
			<label class="ms-1 fs-6 fw-bold fst-italic">@CardItem.ImageFileName</label>
		</div>

		<div class="card-body d-flex flex-column">

			<div class="mb-3">
				<label class="form-label fw-bold">Change Image</label>
				<InputFile OnChange="@(e => UploadNewImageEditFeatureCardClick(e, CardItem.EntryID))" class="form-control" accept=".jpg,.png,.jpeg" />
			</div>

			<div class="mb-3">
				<label for="cardTitle @CardItem.EntryID" class="form-label fw-bold">Card Title</label>
				<textarea class="form-control form-control-lg rounded-3"
						  id="cardTitle @CardItem.EntryID"
						  rows="2"
						  @bind="CardItem.CardTitle"
						  placeholder="Enter card title"
						  style="font-size: 0.9rem; resize: none;">															  
					  </textarea>
			</div>

			<div class="mb-3">
				<label for="cardDesc @CardItem.EntryID" class="form-label fw-bold">Card Description</label>
				<textarea class="form-control form-control-lg rounded-3"
						  id="cardDesc @CardItem.EntryID"
						  rows="3"
						  @bind="CardItem.CardDescription"
						  placeholder="Enter card description"
						  style="font-size: 0.9rem; resize: none;">															  
					  </textarea>
			</div>

			<button type="button" @onclick="() => EditFeatureCardClick(CardItem.EntryID)" class="btn btn-success w-100 py-2 fw-bold rounded-3 border-0 mb-2">
				Edit Card
			</button>
			<button type="button" @onclick="() => DeleteFeatureCardClick(CardItem.EntryID)" class="btn btn-danger w-100 py-2 fw-bold rounded-3 border-0">
				Delete Card
			</button>
			@if (ShowErrorMessage)
			{
				<div class="alert alert-danger mt-3 p-2 small border-0">
					@ErrorMessage
				</div>
			}
		</div>
	</div>

</div>

@code {
	[Parameter] public FeatureCard CardItem { get; set; } = new FeatureCard();
	[Parameter] public List<FeatureCard> CardItemList { get; set; } = new List<FeatureCard>();
	string CardImageUrl = string.Empty;

	[Inject] private IContentManagementService? contentManagementService { get; set; }
	[Inject] private IOptions<AppSettings>? AppSettings { get; set; }
	FeatureCard NewFeatureCard = new FeatureCard();

	bool ShowErrorMessage = false;
	string ErrorMessage = string.Empty;

	protected override void OnParametersSet()
	{
		CardImageUrl = $"data:{CardItem.ImageContentType};base64,{Convert.ToBase64String(CardItem.CardImage)}";
	}


	private async Task EditFeatureCardClick(int EntryId)
	{
		try
		{
			if (contentManagementService != null)
			{
				var featureCard = CardItemList.FirstOrDefault(card => card.EntryID == EntryId);
				if (featureCard != null)
				{
					if (featureCard.CardImage != null && featureCard.CardImage.Length > 0)
					{
						if (!string.IsNullOrWhiteSpace(featureCard.CardTitle) && !string.IsNullOrWhiteSpace(featureCard.CardDescription))
						{
							var result = await contentManagementService.EditFeatureCardInformation(featureCard);
							if (result)
							{
								CustomFunctions.WriteConsoleLog("INFOR", $"UploadContentsPage.EditFeatureCardClick(): result == True");
							}
							else
							{
								CustomFunctions.WriteConsoleLog("ERROR", $"UploadContentsPage.EditFeatureCardClick(): result == False");
							}
						}
						else
						{
							ErrorMessage = "Entry fields cannot be empty, Please fill them all.";
							ShowErrorMessage = true;
						}
					}
					else
					{
						ErrorMessage = "An Image must be uploaded, Please upload an Image.";
						ShowErrorMessage = true;
					}
				}
			}
		}
		catch (Exception ex)
		{
			CustomFunctions.WriteConsoleLog("ERROR", $"Exception Occured UploadContentsPage.EditFeatureCardClick(): {ex.ToString()}");
		}
	}

	private async Task DeleteFeatureCardClick(int EntryId)
	{
		try
		{
			if (contentManagementService != null)
			{
				var result = await contentManagementService.DeleteFeatureCardInformation(EntryId);
				if (result)
				{
					CardItemList.Clear();
					var featureCards = await contentManagementService.GetAllFeatureCardInformation();
					if (featureCards != null && featureCards.Count > 0)
					{
						CardItemList = featureCards;
					}
					CustomFunctions.WriteConsoleLog("INFOR", $"UploadContentsPage.DeleteFeatureCardClick(): result == True");
				}
				else
				{
					CustomFunctions.WriteConsoleLog("ERROR", $"UploadContentsPage.DeleteFeatureCardClick(): result == False");
				}
			}
		}
		catch (Exception ex)
		{
			CustomFunctions.WriteConsoleLog("ERROR", $"Exception Occured UploadContentsPage.DeleteFeatureCardClick(): {ex.ToString()}");
		}
	}

	private async Task UploadNewImageEditFeatureCardClick(InputFileChangeEventArgs e, int EntryId)
	{
		try
		{
			var selectedImage = e.File;
			if (selectedImage != null && AppSettings != null)
			{
				var featureCard = CardItemList.FirstOrDefault(card => card.EntryID == EntryId);
				if (featureCard != null)
				{
					using var stream = selectedImage.OpenReadStream(1024 * 1024 * Convert.ToInt32(AppSettings.Value.MaxImageUploadSizeInMB));
					using var memoryStream = new MemoryStream();
					await stream.CopyToAsync(memoryStream);

					featureCard.CardImage = memoryStream.ToArray();
					featureCard.ImageFileName = selectedImage.Name;
					featureCard.ImageContentType = selectedImage.ContentType;
				}
			}
		}
		catch (Exception ex)
		{
			CustomFunctions.WriteConsoleLog("ERROR", $"Exception Occured UploadContentsPage.UploadNewImageEditFeatureCardClick(): {ex.ToString()}");
		}
	}


}
