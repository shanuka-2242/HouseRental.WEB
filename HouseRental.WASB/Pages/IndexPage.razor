@page "/"

<PageTitle>Rent a Villa</PageTitle>

@* Hero banner *@
<div class="container-fluid p-0 position-relative">

	<img src="images/hero-banner.jpg" class="img-fluid w-100" style="max-height:450px; object-fit:cover;" />

	<div class="position-absolute top-0 start-0 w-100 h-100 bg-dark opacity-50"></div>

	<div class="position-absolute top-50 start-0 text-start translate-middle-y ms-5 text-white">
		<h1 class="display-4 fw-bold">
			@HouseInformation.VillaName
		</h1>
		<p class="lead mt-4">
			@HouseInformation.Description
		</p>
		<button @onclick="ShowMoreDetails" class="viewdetails-btn mt-4">View More Details</button>
	</div>

</div>

@* House features *@
<div class="container mt-5">
	<h1 class="display-5 fw-bold mb-3 text-center">
		Features
	</h1>
	<div class="row text-start">

		@if (IsLoadingFeatureCards)
		{
			<div class="d-flex justify-content-center align-items-center gap-3">
				Fetching information, please wait
				<div class="spinner-border" role="status"></div>
			</div>
		}
		else
		{
			if (IsFeatureCardsExist)
			{
				foreach (var featureCard in FeatureCards)
				{
					string strImageURL = $"data:{featureCard.ImageContentType};base64,{Convert.ToBase64String(featureCard.CardImage)}";

					<div class="col-md-4 p-2 d-flex">
						<div class="card shadow-sm h-100 w-100 feature-card" style="border: none; border-radius: 8px; transition: transform 0.2s;">

							<img src="@strImageURL"
								 class="card-img-top"
								 alt="@featureCard.CardTitle"
								 style="height: 300px; object-fit: cover; border-top-left-radius: 8px; border-top-right-radius: 8px;">

							<div class="card-body d-flex flex-column">
								<h5 class="card-title fw-bold text-dark">
									@featureCard.CardTitle
								</h5>
								<p class="card-text text-muted">
									@featureCard.CardDescription
								</p>
							</div>
						</div>
					</div>
				}
			}
			else
			{
				<div class="container">
					<div class="alert alert-danger d-flex align-items-center border-1 border-danger" role="alert">
						<div>
							<strong>Feature items are currently missing.</strong>
						</div>
					</div>
				</div>
			}
		}

	</div>
</div>

<div class="container mt-5 text-center">
	<h1 class="display-5 fw-bold mb-3">
		Gallery
	</h1>

	@* House images *@
	<div class="row">
		@if (IsLoadingHouseImages)
		{
			<div class="d-flex justify-content-center align-items-center gap-3">
				Fetching information, please wait
				<div class="spinner-border" role="status"></div>
			</div>
		}
		else
		{
			if (IsHouseImagesExist)
			{
				foreach (var houseImage in HouseImages)
				{
					string strImageURL = $"data:{houseImage.ImageContentType};base64,{Convert.ToBase64String(houseImage.Image)}";

					<div class="col-md-4 p-2">
						<img src="@strImageURL" class="house-image img-fluid w-100" />
					</div>
				}
			}
			else
			{
				<div class="container">
					<div class="alert alert-danger d-flex align-items-center border-1 border-danger" role="alert">
						<div>
							<strong>House images currently missing.</strong>
						</div>
					</div>
				</div>
			}
		}
	</div>

</div>

@* Top Destinations *@
<div class="container mt-5 text-center">
	<h1 class="display-5 fw-bold mb-3">
		Top Destinations
	</h1>

	<div class="row text-start">

		@if (IsLoadingDestinationCards)
		{
			<div class="d-flex justify-content-center align-items-center gap-3">
				Fetching information, please wait
				<div class="spinner-border" role="status"></div>
			</div>
		}
		else
		{
			if (IsDestinationCardsExist)
			{
				@foreach (var destinationCard in DestinationCards)
				{
					string strImageURL = $"data:{destinationCard.ImageContentType};base64,{Convert.ToBase64String(destinationCard.CardImage)}";

					<div class="col-md-4 p-2 d-flex">
						<div class="card shadow-sm h-100 w-100 destination-card" style="border: none; border-radius: 8px; transition: transform 0.2s;">

							<img src="@strImageURL"
								 class="card-img-top"
								 alt="@destinationCard.CardTitle"
								 style="height: 300px; object-fit: cover; border-top-left-radius: 8px; border-top-right-radius: 8px;">

							<div class="card-body d-flex flex-column">
								<h5 class="card-title fw-bold text-dark">
									@destinationCard.CardTitle
								</h5>
								<p class="card-text text-muted">
									@destinationCard.CardDescription
								</p>
								<p class="card-text">
									<small class="text-muted">
										@destinationCard.Distance
									</small>
								</p>
							</div>
						</div>
					</div>
				}
			}
			else
			{
				<div class="container">
					<div class="alert alert-danger d-flex align-items-center border-1 border-danger" role="alert">
						<div>
							<strong>Destination items are currently missing.</strong>
						</div>
					</div>
				</div>
			}
		}

	</div>
</div>

@* More info message box *@
@if (ShowMoreDeatils)
{
	<div class="modal-backdrop fade show"></div>

	<div class="modal fade show d-block" tabindex="-1">
		<div class="modal-dialog modal-dialog-centered">
			<div class="modal-content border-0">

				<div class="modal-header border-0 pb-0">
					<button type="button" class="btn-close" @onclick="CloseMoreDeatils"></button>
				</div>

				<div class="modal-body p-4">

					<h3 class="fw-bold mb-3">@HouseInformation.VillaName</h3>

					<div class="text-muted d-flex align-items-center">
						<i class="bi bi-geo-alt-fill me-2 text-danger"></i>
						<span>@HouseInformation.Address</span>
					</div>

					<hr class="text-muted opacity-25">

					<div class="p-3 bg-info bg-opacity-25 rounded-3">
						<h5 class="fw-bold mb-3">Contact Information</h5>

						<div class="mb-2 text-muted d-flex align-items-center">
							<i class="bi bi-person-fill me-2 text-primary"></i>
							<span>@HouseInformation.OwnerName</span>
						</div>

						<div class="mb-2 text-muted d-flex align-items-center">
							<i class="bi bi-phone-fill me-2 text-primary"></i>
							<span>@HouseInformation.MobileNumber</span>
						</div>

						<a href="mailto:@HouseInformation.OwnerEmail">
							<i class="bi bi-envelope-fill me-2 text-primary"></i> @HouseInformation.OwnerEmail
						</a>
					</div>
				</div>
			</div>
		</div>
	</div>
}

@code {
	[Inject] private IContentManagementService? contentManagementService { get; set; }
	List<FeatureCard> FeatureCards = new List<FeatureCard>();
	List<DestinationCard> DestinationCards = new List<DestinationCard>();
	List<HouseImage> HouseImages = new List<HouseImage>();
	HouseInformation HouseInformation = new HouseInformation();

	private bool ShowMoreDeatils = false;

	private bool IsLoadingFeatureCards = true;
	private bool IsFeatureCardsExist = false;

	private bool IsLoadingDestinationCards = true;
	private bool IsDestinationCardsExist = false;

	private bool IsLoadingHouseImages = true;
	private bool IsHouseImagesExist = false;

	protected override async Task OnInitializedAsync()
	{
		try
		{
			if (contentManagementService != null)
			{
				var featureCards = await contentManagementService.GetAllFeatureCardInformation();
				var destinationCards = await contentManagementService.GetAllDestinationCardInformation();
				var houseImages = await contentManagementService.GetAllHouseImages();
				var houseInformation = await contentManagementService.GetHouseInformation();

				if (featureCards != null && featureCards.Count > 0)
				{
					FeatureCards = featureCards;
					IsLoadingFeatureCards = false;
					IsFeatureCardsExist = true;
				}
				else
				{
					IsLoadingFeatureCards = false;
					IsFeatureCardsExist = false;
				}

				if (destinationCards != null && destinationCards.Count > 0)
				{
					DestinationCards = destinationCards;
					IsLoadingDestinationCards = false;
					IsDestinationCardsExist = true;
				}
				else
				{
					IsLoadingDestinationCards = false;
					IsDestinationCardsExist = false;
				}

				if (houseImages != null && houseImages.Count > 0)
				{
					HouseImages = houseImages;
					IsLoadingHouseImages = false;
					IsHouseImagesExist = true;
				}
				else
				{
					IsLoadingHouseImages = false;
					IsHouseImagesExist = false;
				}

				if (houseInformation != null)
				{
					HouseInformation = houseInformation;
				}
			}
			else
			{
				CustomFunctions.WriteConsoleLog("ERROR", "IndexPage.OnInitializedAsync(): contentManagementService is null.");
			}
		}
		catch (Exception ex)
		{
			CustomFunctions.WriteConsoleLog("ERROR", $"Exception occurred: IndexPage.OnInitializedAsync(): {ex.ToString()}");
		}
	}

	private void ShowMoreDetails()
	{
		ShowMoreDeatils = true;
	}

	private void CloseMoreDeatils()
	{
		ShowMoreDeatils = false;
	}
}