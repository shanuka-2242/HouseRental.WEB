@page "/admin-login"

<PageTitle>Admin Login</PageTitle>

<div class="container d-flex justify-content-center align-items-center vh-100">
    <div class="card shadow-sm border-0 p-4" style="width: 100%; max-width: 400px; border-radius: 15px;">
        <div class="card-body">
            <h3 class="text-center fw-bold mb-4">Admin Login</h3>

            <form>
                <div class="mb-3">
                    <label for="exampleInputEmail1" class="form-label fw-semibold">Email address</label>
                    <input type="email" class="form-control form-control-lg px-3"
                           id="exampleInputEmail1" placeholder="name@example.com"
                           style="border-radius: 10px; font-size: 0.9rem;">
                </div>

                <div class="mb-3">
                    <div class="d-flex justify-content-between">
                        <label for="exampleInputPassword1" class="form-label fw-semibold">Password</label>
                    </div>
                    <input type="password" class="form-control form-control-lg px-3"
                           id="exampleInputPassword1" placeholder="Enter your password"
                           style="border-radius: 10px; font-size: 0.9rem;">
                </div>

                <button type="submit" class="btn btn-primary w-100 py-2 fw-bold"
                        style="border-radius: 10px; background-color: #0d6efd;">
                        Log In
                </button>
            </form>
        </div>
    </div>
</div>

@code {

}
