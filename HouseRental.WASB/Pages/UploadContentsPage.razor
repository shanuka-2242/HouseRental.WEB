@page "/upload-contents"
@* @attribute [Authorize] *@

<PageTitle>Upload Contents</PageTitle>

<div class="container-fluid p-4">

	<h1 class="display-6 fw-bold mt-2 mb-4 text-center">
		Manage House Featues
	</h1>

	<div class="row text-start">
		@if (IsLoadingFeatureCards)
		{
			<div class="col-md-3">
				<FetchingInformationLoading />
			</div>
		}
		else
		{
			if (FeatureCards.Count > 0)
			{
				foreach (var featureCard in FeatureCards)
				{
					<ManageHouseFeatureCard OnHouseFeatureItemChanged="HouseFeatureItemChanged" CardItem="featureCard" />
				}
			}
		}		

		<div class="col-md-3 p-2">
			<div class="d-flex align-items-center justify-content-center bg-light rounded-3 p-4 border-1 border-secondary h-100 shadow-sm" style="border: dashed;">
				<button type="button" @onclick="ShowAddFeatureFormClick" class="btn btn-primary d-inline-flex align-items-center gap-2 px-3 py-2">
					<i class="bi bi-plus-circle-dotted fs-5"></i>
					<span>Add New Item</span>
				</button>
			</div>
		</div>
	</div>
</div>

@*Add House Feature Card Form*@
@if (ShowAddHouseFeatureForm)
{
	<AddHouseFeatureForm OnFormClose="AddFeatureFormOnClose" />
}

@code {
	[Inject] private IContentManagementService? contentManagementService { get; set; }
	List<FeatureCard> FeatureCards = new List<FeatureCard>();
	bool ShowAddHouseFeatureForm = false;
	private bool IsLoadingFeatureCards = true;

	protected override async Task OnInitializedAsync()
	{
		try
		{
			await FatchDefinedItemsFromDataBase("HOUSE_FEATURE_CARDS");
		}
		catch (Exception ex)
		{
			CustomFunctions.WriteConsoleLog("ERROR", $"Exception Occured UploadContentsPage.OnInitializedAsync(): {ex.ToString()}");
		}
	}

	private async Task FatchDefinedItemsFromDataBase(string itemCategoryName)
	{
		try
		{
			if (contentManagementService != null)
			{
				switch (itemCategoryName)
				{
					case "HOUSE_FEATURE_CARDS":
						FeatureCards.Clear();
						var featureCards = await contentManagementService.GetAllFeatureCardInformation();
						if (featureCards != null && featureCards.Count > 0)
						{
							FeatureCards = featureCards;
						}
						IsLoadingFeatureCards = false;
						break;
				}
			}
			else
			{
				CustomFunctions.WriteConsoleLog("ERROR", "UploadContentsPage.FatchDefinedItemsFromDataBase(): contentManagementService is null.");
			}
		}
		catch (Exception ex)
		{
			CustomFunctions.WriteConsoleLog("ERROR", $"Exception Occured UploadContentsPage.FatchDefinedItemsFromDataBase(): {ex.ToString()}");
		}			
	}

	private void ShowAddFeatureFormClick()
	{
		ShowAddHouseFeatureForm = true;
	}

	private async Task AddFeatureFormOnClose()
	{
		ShowAddHouseFeatureForm = false;
		await FatchDefinedItemsFromDataBase("HOUSE_FEATURE_CARDS");
	}

	private async Task HouseFeatureItemChanged()
	{		
		await FatchDefinedItemsFromDataBase("HOUSE_FEATURE_CARDS");
	}
}
