<div class="modal-backdrop fade show"></div>

<div class="modal fade show d-block" tabindex="-1">
	<div class="modal-dialog modal-dialog-scrollable">
		<div class="modal-content border-0">

			<div class="modal-header border-0 mb-3 pb-0">
				<button type="button" class="btn-close" @onclick="CloseFeatureCardForm"></button>
			</div>

			<div class="modal-body p-3">

				<h3 class="fw-bold text-center">Add House Feature</h3>

				<hr class="text-muted opacity-25">

				<div class="card h-100 w-100">

					<img src="@CardImageUrl"
						 class="card-img-top"
						 style="height: 300px; object-fit: cover;">

					<div class="card-body d-flex flex-column">

						<div class="mb-3">
							<label class="form-label fw-bold">Add Image</label>
							<InputFile OnChange="@UploadNewImage" class="form-control" accept=".jpg,.png,.jpeg" />
						</div>

						<div class="mb-3">
							<label for="cardTitle" class="form-label fw-bold">Card Title</label>
							<textarea class="form-control form-control-lg rounded-3"
									  id="cardTitle"
									  rows="2"
									  @bind="NewFeatureCard.CardTitle"
									  placeholder="Enter card title"
									  style="font-size: 0.9rem; resize: none;">
															  </textarea>
						</div>

						<div class="mb-3">
							<label for="cardDesc" class="form-label fw-bold">Card Description</label>
							<textarea class="form-control form-control-lg rounded-3"
									  id="cardDesc"
									  rows="3"
									  @bind="NewFeatureCard.CardDescription"
									  placeholder="Enter card description"
									  style="font-size: 0.9rem; resize: none;">
															  </textarea>
						</div>

						<button type="button" @onclick="AddFeatureCardClick" class="btn btn-primary w-100 py-2 fw-bold rounded-3 border-0">
							Add Item
						</button>
						@if (ShowAlert)
						{
							<AlertComponent AlertColor="@AlertColor" AlertMessage="@AlertMessage" />
						}
					</div>
				</div>

			</div>
		</div>

	</div>
</div>

@code {
	[Parameter] public EventCallback OnClose { get; set; }
	[Inject] private IContentManagementService? contentManagementService { get; set; }
	[Inject] private IOptions<AppSettings>? AppSettings { get; set; }
	FeatureCard NewFeatureCard = new FeatureCard();
	bool ShowAlert = false;
	string AlertMessage = string.Empty;
	string AlertColor = string.Empty;
	string CardImageUrl = "/images/upload-image.png";

	private async Task CloseFeatureCardForm()
	{
		await OnClose.InvokeAsync();
	}

	private async Task UploadNewImage(InputFileChangeEventArgs e)
	{
		try
		{
			var selectedImage = e.File;
			if (selectedImage != null && AppSettings != null)
			{
				using var stream = selectedImage.OpenReadStream(1024 * 1024 * Convert.ToInt32(AppSettings.Value.MaxImageUploadSizeInMB));
				using var memoryStream = new MemoryStream();
				await stream.CopyToAsync(memoryStream);

				NewFeatureCard.CardImage = memoryStream.ToArray();
				NewFeatureCard.ImageFileName = selectedImage.Name;
				NewFeatureCard.ImageContentType = selectedImage.ContentType;
				CardImageUrl = $"data:{NewFeatureCard.ImageContentType};base64,{Convert.ToBase64String(NewFeatureCard.CardImage)}";
			}
		}
		catch (Exception ex)
		{
			CustomFunctions.WriteConsoleLog("ERROR", $"Exception Occured AddHouseFeatureCardComponent.UploadNewImage(): {ex.ToString()}");
		}
	}

	private async Task AddFeatureCardClick()
	{
		try
		{
			if (contentManagementService != null)
			{
				if (NewFeatureCard.CardImage != null && NewFeatureCard.CardImage.Length > 0)
				{
					if (!string.IsNullOrWhiteSpace(NewFeatureCard.CardTitle) && !string.IsNullOrWhiteSpace(NewFeatureCard.CardDescription))
					{
						var result = await contentManagementService.AddFeatureCardInformation(NewFeatureCard);
						if (result)
						{
							AlertMessage = "Add request processed sucessfully.";
							AlertColor = "success";
							ShowAlert = true;
						}
						else
						{
							AlertMessage = "Add request failed. Please try again.";
							AlertColor = "danger";
							ShowAlert = true;
						}
					}
					else
					{
						AlertMessage = "Entry fields cannot be empty, Please fill them all.";
						AlertColor = "danger";
						ShowAlert = true;
					}
				}
				else
				{
					AlertMessage = "Image must be uploaded, Please upload an Image.";
					AlertColor = "danger";
					ShowAlert = true;
				}
			}
			else
			{
				CustomFunctions.WriteConsoleLog("ERROR", "AddHouseFeatureCardComponent.AddFeatureCardClick(): contentManagementService is null.");
			}
		}
		catch (Exception ex)
		{
			AlertMessage = "Exception occurred, please check console logs and contact the developer.";
			AlertColor = "danger";
			ShowAlert = true;
			CustomFunctions.WriteConsoleLog("ERROR", $"Exception Occured AddHouseFeatureCardComponent.AddFeatureCardClick(): {ex.ToString()}");
		}
	}
}
