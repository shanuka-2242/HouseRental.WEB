@page "/admin-login"

<PageTitle>Admin Login</PageTitle>

<div class="container d-flex justify-content-center align-items-center vh-100">
    <div class="card shadow-sm border-0 p-4 rounded-3" style="width: 100%; max-width: 400px;">
        <div class="card-body">
            <h3 class="text-center fw-bold mb-4">Admin Login</h3>

            <EditForm Model="@adminUser">
                <div class="mb-3">
                    <label for="email" class="form-label fw-semibold">Email address</label>
                    <input type="email" class="form-control form-control-lg px-3 rounded-3"
                           id="email" placeholder="Enter your email"
                           @bind-value="adminUser.Email" @bind-value:event="oninput"
                           style="font-size: 0.9rem;">
                </div>

                <div class="mb-3">
                    <label for="password" class="form-label fw-semibold">Password</label>
                    <input type="password" class="form-control form-control-lg px-3 rounded-3"
                           id="password" placeholder="Enter your password"
                           @bind-value="adminUser.Password" @bind-value:event="oninput"
                           style="font-size: 0.9rem;">
                </div>

                <button type="submit" @onclick="LoginClick" class="btn btn-primary w-100 py-2 fw-bold rounded-3 border-0">
                    Log In
                </button>

                @if (ShowErrorMessage)
                {
                    <div class="alert alert-danger mt-3 p-2 small border-0">
                        @ErrorMessage                        
                    </div>
                }
            </EditForm>
        </div>
    </div>
</div>

@code {
    AdminUser adminUser = new AdminUser();
    string ErrorMessage = string.Empty;
    bool ShowErrorMessage = false;
    [Inject] private AuthenticationStateProvider? AuthProvider { get; set; }
    [Inject] private NavigationManager? NavigationManager { get; set; }

    // admin@gmail.com - 7932B2E116B076A54F452848EAABD5857F61BD957FE8A218FAF216F24C9885BB
    // Admin@4321      - 7CCC547ECB954714B2495951D0108E4E99DDA62685C6C6551F43137B731F486C

    private void LoginClick()
    {
        if (!string.IsNullOrWhiteSpace(adminUser.Email) 
        && !string.IsNullOrWhiteSpace(adminUser.Password))
        {
            var encryptedEmail = CustomFunctions.GenerateUniqueId(adminUser.Email);
            var encryptedPassword = CustomFunctions.GenerateUniqueId(adminUser.Password);

            if (encryptedEmail == "7932B2E116B076A54F452848EAABD5857F61BD957FE8A218FAF216F24C9885BB" 
            && encryptedPassword == "7CCC547ECB954714B2495951D0108E4E99DDA62685C6C6551F43137B731F486C")
            {
                if (AuthProvider != null && NavigationManager != null)
                {
                    var customService = (CustomAuthStateProvider)AuthProvider;
                    customService.NotifyUserLogin(adminUser.Email);
                    NavigationManager.NavigateTo("/upload-contents");
                }
                else
                {
                    CustomFunctions.WriteConsoleLog("ERROR", "AdminLoginPage.LoginClick(): AuthProvider is null OR NavigationManager is null.");
                }
            }
            else
            {
                ErrorMessage = "Entered email or password is incorrect.";
                ShowErrorMessage = true;
            }
        }
        else
        {
            ErrorMessage = "Entry fields cannot be empty.";
            ShowErrorMessage = true;
        }
    }
}
