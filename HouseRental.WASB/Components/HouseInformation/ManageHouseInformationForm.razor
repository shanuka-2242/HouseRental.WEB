<form class="row g-3 rounded-3 border-1 p-2 border-secondary" style="border-style: solid;">
    <div class="form-group">
        <label for="villaNameInput">House Name</label>
        <input type="text"
            class="form-control" 
            id="villaNameInput"               
            placeholder="House Name"
            @bind="HouseInformation.VillaName">
    </div>
    <div class="form-group">
        <label for="houseDescriptionInput">House Description</label>
        <textarea class="form-control" 
        id="houseDescriptionInput" 
        rows="3"
        @bind="HouseInformation.Description">
    </textarea>
    </div>
    <div class="form-group">
        <label for="addressInput">House Address</label>
        <input type="text"
               class="form-control"
               id="addressInput"
               placeholder="Address"
               @bind="HouseInformation.Address">
    </div>
    <div class="form-group">
        <label for="mobileNumbrInput">Mobile Number</label>
        <input type="text"
               class="form-control"
               id="mobileNumbrInput"
               placeholder="Mobile Number"
               @bind="HouseInformation.MobileNumber">
    </div>
    <div class="form-group">
        <label for="ownerNameInput">Owner Name</label>
        <input type="text"
               class="form-control"
               id="ownerNameInput"
               placeholder="Owner Name"
               @bind="HouseInformation.OwnerName">
    </div>
    <div class="form-group">
        <label for="ownerEmailInput">Owner Email</label>
        <input type="text"
               class="form-control"
               id="ownerEmailInput"
               placeholder="Owner Email"
               @bind="HouseInformation.OwnerEmail">
    </div>
    <div class="form-group">
        <button type="button" @onclick="EditHouseInformationClick" class="btn btn-primary w-100 py-2 fw-bold rounded-3 border-0">
            Edit House Information
        </button>
    </div>
    @if (ShowAlert)
    {
        <div class="form-group m-0">
            <FormAlert AlertColor="@AlertColor" AlertMessage="@AlertMessage" />
        </div>
    }
</form>

@code {
    [EditorRequired]
    [Parameter] public HouseInformation HouseInformation { get; set; } = new HouseInformation();
    [Inject] private IContentManagementService? contentManagementService { get; set; }
    string AlertMessage = string.Empty;
    string AlertColor = string.Empty;
    bool ShowAlert = false;

    private async Task EditHouseInformationClick()
    {
        try
        {
            if (contentManagementService != null)
            {
                if (
                    !string.IsNullOrWhiteSpace(HouseInformation.VillaName) &&                 
                    !string.IsNullOrWhiteSpace(HouseInformation.Description) &&
                    !string.IsNullOrWhiteSpace(HouseInformation.Address) &&
                    !string.IsNullOrWhiteSpace(HouseInformation.MobileNumber) &&
                    !string.IsNullOrWhiteSpace(HouseInformation.OwnerName) &&
                    !string.IsNullOrWhiteSpace(HouseInformation.OwnerEmail)
                )
                {
                    var result = await contentManagementService.EditHouseInformation(HouseInformation);
                    if (result)
                    {
                        AlertMessage = "House information edited sucessfully.";
                        AlertColor = "success";
                        ShowAlert = true;
                    }
                    else
                    {
                        AlertMessage = "House information editing process failed. Please try again.";
                        AlertColor = "danger";
                        ShowAlert = true;
                    }
                }
                else
                {
                    AlertMessage = "Entry fields cannot be empty, Please fill them all.";
                    AlertColor = "danger";
                    ShowAlert = true;
                }
            }
            else
            {
                CustomFunctions.WriteConsoleLog("ERROR", "ManageHouseInformationForm.EditHouseInformationClick(): contentManagementService is null.");
            }
        }
        catch (Exception ex)
        {
            AlertMessage = "Exception occurred, please check console logs and contact the developer.";
            AlertColor = "danger";
            ShowAlert = true;
            CustomFunctions.WriteConsoleLog("ERROR", $"Exception Occured ManageHouseInformationForm.EditHouseInformationClick(): {ex.ToString()}");
        }
    }

}
